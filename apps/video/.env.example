# Sanity App SDK env. The CLI inlines every SANITY_APP_* var into the client
# bundle at build time (Vite-style define), so DO NOT put real server secrets
# here that you wouldn't ship to the browser. Copy to `.env` to use locally.

# Sanity project id the app reads/writes against.
SANITY_APP_PROJECT_ID=your_project_id
# Sanity dataset name, e.g. "production".
SANITY_APP_DATASET=production
# Organization that owns the deployed app (Sanity Manage > your org). Used by sanity.cli.ts.
SANITY_APP_ORGANIZATION_ID=your_org_id

# Full URL to the web app's render endpoint (NOT just an origin).
# Local: http://localhost:3000/api/video/render
SANITY_APP_RENDER_API_URL=http://localhost:3000/api/video/render

# Bearer token sent to the render endpoint. Must equal the web app's
# VIDEO_RENDER_SECRET. NOTE: because it carries the SANITY_APP_ prefix it is
# bundled into the client JS — acceptable for a local/demo app, but for a public
# deployment you'd proxy the render call through a server you control instead of
# shipping this secret to the browser. See the repo README.
SANITY_APP_RENDER_SECRET=your_long_random_secret
