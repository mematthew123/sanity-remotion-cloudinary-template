# BlueSky account credentials. Create an "app password" at
# https://bsky.app/settings/app-passwords — do NOT use your account password.
BLUESKY_USERNAME=your-handle.bsky.social
BLUESKY_PASSWORD=xxxx-xxxx-xxxx-xxxx
BLUESKY_HOST=bsky.social

# Sanity write access — required because the function patches video.socialPostedAt
# after a successful post. Generate at sanity.io/manage → tokens with Editor role.
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_WRITE_TOKEN=your_editor_scope_token

# Public site URL used to build the link appended to the BlueSky post body.
# Should match NEXT_PUBLIC_SITE_URL in apps/web/.env.local.
SITE_URL=https://your-site.com
