# Sanity project the Studio connects to.
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# The web app's render endpoint that the "Render" document action calls.
# Local: http://localhost:3000/api/video/render
# Production: https://renderonce.dev/api/video/render
SANITY_STUDIO_RENDER_API_URL=http://localhost:3000/api/video/render

# Shared secret sent as `Authorization: Bearer <secret>` to the render route.
# NOTE: every SANITY_STUDIO_* var is inlined into the client JS bundle by Vite,
# so this secret IS shipped to the browser. That is acceptable for local/demo
# use only — see the repo README security note before deploying. For production,
# move rendering behind an authenticated server route instead of a bearer token.
SANITY_STUDIO_RENDER_SECRET=replace-with-a-shared-secret

# Shared secret for the "Send newsletter" action — must equal the web app's
# NEWSLETTER_SEND_SECRET. Same client-bundle caveat as the render secret above.
SANITY_STUDIO_NEWSLETTER_SECRET=replace-with-a-shared-secret
