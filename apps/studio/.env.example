# Sanity project the Studio connects to.
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# The web app's render endpoint that the "Render" document action calls.
# Local: http://localhost:3000/api/video/render
# Production: https://renderonce.dev/api/video/render
SANITY_STUDIO_RENDER_API_URL=http://localhost:3000/api/video/render

# Base origin the newsletter actions (preview / welcome-email / send) POST to.
# Falls back to http://localhost:3000 when unset — set it to your deployed web
# app origin (e.g. https://renderonce.dev) so newsletter previews and sends hit
# the right host in production.
SANITY_STUDIO_NEWSLETTER_API_URL=http://localhost:3000

# Web app origin for the Presentation tool's live preview (prod: your site URL).
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000



# Shared secret for the "Send newsletter" action — must equal the web app's
# NEWSLETTER_SEND_SECRET. Same client-bundle caveat as the render secret above.
SANITY_STUDIO_NEWSLETTER_SECRET=replace-with-a-shared-secret

# Enable the `article-narrated` long-form composition (TTS reading of the post
# body). Off by default: it needs ElevenLabs (ELEVENLABS_API_KEY/VOICE_ID, a paid
# third party) configured on the web app first. When unset, the Studio hides the
# "Generate voiceover" + "Render narrated reading" actions and drops "Article
# Narrated" from the video template picker. Set to true once ElevenLabs is wired.
# SANITY_STUDIO_ENABLE_NARRATED=true
