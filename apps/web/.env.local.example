# Sanity project id (Manage > API). Public — exposed to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# Sanity dataset name, e.g. "production". Public.
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity token with write access — used by /api/video/render to create video docs. Keep secret.
SANITY_API_WRITE_TOKEN=your_sanity_write_token
# Sanity Viewer (read) token — only needed for draft-mode visual editing. Keep secret.
SANITY_API_READ_TOKEN=your_sanity_viewer_token
# Studio URL for stega click-to-edit overlays (prod: your Studio URL). Public.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
# Shared secret the Studio "Render" action sends as a Bearer token. Keep secret.
VIDEO_RENDER_SECRET=your_long_random_secret
# Cloudinary cloud name (Dashboard > Product Environment).
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Cloudinary API key. Keep secret.
CLOUDINARY_API_KEY=your_cloudinary_api_key
# Cloudinary API secret. Keep secret.
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Canonical public origin — absolute URLs in OG tags, sitemap, RSS, and
# newsletter CTAs. No trailing slash. Leave unset locally to fall back to
# http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://renderonce.dev

# --- Resend (newsletter send + preview) ---
# RESEND_FROM_EMAIL must be on a domain VERIFIED in Resend, or sends bounce /
# land in spam. See docs/configuration.md.
RESEND_API_KEY=your_resend_api_key
RESEND_AUDIENCE_ID=your_resend_audience_id
RESEND_FROM_EMAIL=hello@renderonce.dev
RESEND_FROM_NAME=Render Once
# Shared secret the Studio "Send newsletter" action sends as a Bearer token.
# Mirror identically into apps/studio/.env as SANITY_STUDIO_NEWSLETTER_SECRET.
NEWSLETTER_SEND_SECRET=your_long_random_secret

# --- ElevenLabs TTS (only needed for the `article-narrated` composition) ---
# Powers `pnpm --filter @template/web generate-voiceover`. Leave blank otherwise.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Rendering: local vs Vercel Sandbox ---
# By default, rendering runs in a Vercel Sandbox (see docs/vercel-sandbox.md).
# For that path, set BLOB_READ_WRITE_TOKEN below: locally, run
# `vercel link && vercel env pull apps/web/.env.local` from this directory —
# that single command writes BOTH this token AND the OIDC vars the
# `@vercel/sandbox` SDK uses to authenticate. On Vercel deployments, both are
# injected automatically once a Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=

# LOCAL RENDER (no Vercel needed): leave BLOB_READ_WRITE_TOKEN empty and the
# render route automatically renders with headless Chromium on your machine and
# uploads straight to Cloudinary — so you can clone, configure only Sanity +
# Cloudinary, and see a video without a Vercel project. Chromium downloads once
# on first render. Set LOCAL_RENDER=true to force this path even when a Blob
# token is present. (Ignored on Vercel deployments, which always use the sandbox.)
# LOCAL_RENDER=true
