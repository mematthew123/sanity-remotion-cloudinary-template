# Sanity project id (Manage > API). Public — exposed to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# Sanity dataset name, e.g. "production". Public.
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity token with write access — used by /api/video/render to create video docs. Keep secret.
SANITY_API_WRITE_TOKEN=your_sanity_write_token
# Shared secret the Studio "Render" action sends as a Bearer token. Keep secret.
VIDEO_RENDER_SECRET=your_long_random_secret
# Cloudinary cloud name (Dashboard > Product Environment).
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Cloudinary API key. Keep secret.
CLOUDINARY_API_KEY=your_cloudinary_api_key
# Cloudinary API secret. Keep secret.
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Remotion Lambda (rendering runs on AWS; see docs/lambda.md) ---
# AWS credentials for the Remotion IAM user. Server-only — keep secret.
REMOTION_AWS_ACCESS_KEY_ID=your_aws_access_key_id
REMOTION_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS region the function + site are deployed to. Defaults to us-east-1.
REMOTION_LAMBDA_REGION=us-east-1
# Deployed function name — printed by `pnpm deploy:lambda:fn`.
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-321-mem2048mb-disk2048mb-120sec
# Serve URL of the uploaded site bundle — printed by `pnpm deploy:lambda:site`.
REMOTION_LAMBDA_SERVE_URL=https://remotionlambda-<region>-<hash>.s3.<region>.amazonaws.com/sites/template-video/index.html
