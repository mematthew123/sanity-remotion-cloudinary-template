# Sanity project id (Manage > API). Public — exposed to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# Sanity dataset name, e.g. "production". Public.
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity token with write access — used by /api/video/render to create video docs. Keep secret.
SANITY_API_WRITE_TOKEN=your_sanity_write_token
# Shared secret the Studio "Render" action sends as a Bearer token. Keep secret.
VIDEO_RENDER_SECRET=your_long_random_secret
# Cloudinary cloud name (Dashboard > Product Environment).
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Cloudinary API key. Keep secret.
CLOUDINARY_API_KEY=your_cloudinary_api_key
# Cloudinary API secret. Keep secret.
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Vercel Sandbox (rendering runs on Vercel; see docs/vercel-sandbox.md) ---
# Token for the Vercel Blob store that stages rendered MP4s before they're
# pushed to Cloudinary, and that holds the build-time sandbox snapshot id.
# On Vercel deployments: connect a Blob store to the project (Storage → Create
# → Blob) and this var is auto-injected. Locally:
#   vercel link
#   vercel env pull apps/web/.env.local
BLOB_READ_WRITE_TOKEN=
