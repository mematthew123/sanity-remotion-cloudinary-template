# Sanity project the `video` documents live in (Manage > API).
SANITY_APP_PROJECT_ID=your-project-id

# Sanity dataset, e.g. "production".
SANITY_APP_DATASET=production

# Sanity organization that owns this App SDK app (Manage > Organization settings).
SANITY_APP_ORGANIZATION_ID=your-org-id

# Base URL of the web app that exposes the /api/cloudinary/* proxy routes.
# Local dev points at the Next.js dev server; in prod use your deployed origin.
SANITY_APP_API_BASE=http://localhost:3000

# Cloudinary cloud name — used to build delivery + transform URLs in the browser.
# Must match CLOUDINARY_CLOUD_NAME in the web app.
SANITY_APP_CLOUDINARY_CLOUD_NAME=your-cloud-name
