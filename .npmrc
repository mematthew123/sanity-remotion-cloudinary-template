# Flatten node_modules (npm-style, no symlinks into .pnpm).
#
# Required for the Vercel deployment of /api/video/render: Next.js output-file
# tracing pulls the @remotion/compositor-linux-x64-gnu binary into the function
# via the globs in apps/web/next.config.ts. Under pnpm's default isolated
# linker those paths are symlinks into .pnpm, and Vercel rejects a function
# package that contains symlinked directories ("invalid deployment package").
# A hoisted layout makes them real files, which traces and deploys cleanly.
node-linker=hoisted
shamefully-hoist=true
