{
  "name": "sanity-remotion-cloudinary-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@template/web",
    "dev:studio": "turbo run dev --filter=@template/studio",
    "dev:remotion": "pnpm --filter @template/web dev:remotion",
    "build": "turbo run build --filter=@template/web",
    "build:web": "turbo run build --filter=@template/web",
    "build:studio": "turbo run build --filter=@template/studio",
    "start": "pnpm --filter @template/web start",
    "lint": "turbo run lint",
    "deploy:studio": "pnpm --filter @template/studio deploy",
    "bundle:remotion": "pnpm --filter @template/web bundle:remotion",
    "typegen": "turbo run typegen"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "turbo": "^2.10.0"
  }
}
